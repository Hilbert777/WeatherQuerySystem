{
  "name": "weather-query-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "vite --config client/vite.config.ts --host 127.0.0.1 --port 5173",
    "dev:server": "node server/index.js",
    "build": "vue-tsc -p client/tsconfig.json --noEmit && vite build --config client/vite.config.ts",

    "start": "node server/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "echarts": "^5.5.1",
    "express": "^4.19.2",
    "pinia": "^2.1.7",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.1.0"
  }
}
